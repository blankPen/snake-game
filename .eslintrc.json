{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single"],
    "semi": ["error", "always"],
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "prefer-const": "warn"
  },
  "globals": {
    "window": "readonly",
    "document": "readonly",
    "localStorage": "readonly",
    "requestAnimationFrame": "readonly",
    "performance": "readonly",
    "console": "readonly",
    "Math": "readonly",
    "JSON": "readonly",
    "fetch": "readonly",
    "Audio": "readonly",
    "Image": "readonly",
    "FontFace": "readonly"
  }
}
